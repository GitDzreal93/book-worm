generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Book {
  id                   String     @id @default(cuid())
  slug                 String     @unique
  title                String
  subtitle             String?
  author               String?
  description          String?
  language             String?
  coverImage           Bytes?
  totalChapters        Int        @default(0)
  totalParagraphs      Int        @default(0)
  currentChapterId     String?
  currentParagraphOrder Int?
  readPercentage       Float      @default(0)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  chapters             Chapter[]
  characters           Character[]
  relations            FamilyRelation[]
  vocabularyWords      VocabularyWord[]
  readingSessions      ReadingSession[]
  highlights           Highlight[]
}

model Chapter {
  id        String     @id @default(cuid())
  bookId    String
  book      Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  number    Int
  title     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  paragraphs Paragraph[]
  summary    String?

  @@unique([bookId, number])
  @@index([bookId])
}

model Paragraph {
  id         String    @id @default(cuid())
  chapterId  String
  chapter    Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  order      Int
  content    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  mentions           CharacterMention[]
  translation        ParagraphTranslation?
  highlights         Highlight[]

  @@unique([chapterId, order])
  @@index([chapterId])
}

model Character {
  id         String              @id @default(cuid())
  bookId     String
  book       Book                @relation(fields: [bookId], references: [id], onDelete: Cascade)
  nick       String
  orig       String
  colorClass String
  gen        String
  desc       String
  sortOrder  Int                 @default(0)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  aliases           CharacterAlias[]
  familyAsPerson    FamilyRelation[] @relation("FamilyPerson")
  familyAsRelative  FamilyRelation[] @relation("FamilyRelative")

  @@unique([bookId, nick])
  @@index([bookId])
}

model CharacterMention {
  id                String          @id @default(cuid())
  characterAliasId  String
  characterAlias    CharacterAlias  @relation(fields: [characterAliasId], references: [id], onDelete: Cascade)
  paragraphId       String
  paragraph         Paragraph       @relation(fields: [paragraphId], references: [id], onDelete: Cascade)
  offset            Int
  length            Int

  @@index([characterAliasId])
  @@index([paragraphId])
}

model FamilyRelation {
  id         String    @id @default(cuid())
  bookId     String
  book       Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  personId   String
  relativeId String
  type       String
  note       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  person   Character @relation("FamilyPerson", fields: [personId], references: [id], onDelete: Cascade)
  relative Character @relation("FamilyRelative", fields: [relativeId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([personId])
  @@index([relativeId])
}

model CharacterAlias {
  id         String  @id @default(cuid())
  characterId String
  character  Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  alias      String
  isPrimary  Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mentions CharacterMention[]

  @@unique([characterId, alias])
  @@index([characterId])
}

model ParagraphTranslation {
  id         String   @id @default(cuid())
  paragraphId String
  paragraph  Paragraph @relation(fields: [paragraphId], references: [id], onDelete: Cascade)
  content    String
  isEdited   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([paragraphId])
}

model VocabularyWord {
  id              String       @id @default(cuid())
  bookId          String
  book            Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  word            String
  definition      String
  partOfSpeech    String?
  phonetic        String?
  contextSentence String?
  chapterTitle    String?
  easeFactor      Float        @default(2.5)
  interval        Int          @default(0)
  repetitionCount Int          @default(0)
  nextReviewDate  DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  reviewLogs ReviewLog[]

  @@unique([bookId, word])
  @@index([bookId])
}

model ReviewLog {
  id         String         @id @default(cuid())
  wordId     String
  word       VocabularyWord @relation(fields: [wordId], references: [id], onDelete: Cascade)
  quality    Int
  reviewedAt DateTime       @default(now())

  @@index([wordId])
  @@index([wordId, reviewedAt])
}

model Highlight {
  id          String    @id @default(cuid())
  paragraphId String
  paragraph   Paragraph @relation(fields: [paragraphId], references: [id], onDelete: Cascade)
  bookId      String
  book        Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  startOffset Int
  endOffset   Int
  color       String    @default("yellow")
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([paragraphId])
  @@index([bookId])
}

model ReadingSession {
  id             String    @id @default(cuid())
  bookId         String
  book           Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  chaptersRead   Int       @default(0)
  paragraphsRead Int       @default(0)

  @@index([bookId])
  @@index([bookId, startedAt])
}

model AiSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
